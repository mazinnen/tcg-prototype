    "BTR2-029": {
      "name": "星座になれたら 喜多郁代",
      "type": "",
      "text": "【結束：スペード/ハート/クラブ】 ⁅自動⁆あなたのテリトリー開放中にこのユニットがアタックしてバトルに勝利した時、あなたのエナジーが３色以上なら、あなたの手札を１枚ドロップしてよい。そうしたら、山札をシャッフルして上から１枚ライフの先頭に置く。"
    },
    "BTR2-030": {
      "name": "Distortion!! 喜多郁代",
      "type": "",
      "text": "【結束：スペード/ハート/クラブ】 ⁅自動⁆あなたの称号「STARRY」のテリトリー開放中にこのユニットがアタックした時、このターンあなたが【結束】でカードを引いていたら、あなたのドロップゾーンのユニットカードを１枚エナジーゾーンに置く。"
    },
    "BTR2-031": {
      "name": "",
      "type": "",
      "text": ""
